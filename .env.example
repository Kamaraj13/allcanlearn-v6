# ============================================================
#  AllCanLearn — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ============================================================


# ── API Keys ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here


# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Set to "production" on Ubuntu, "development" on Mac
ENV=production


# ── Database ─────────────────────────────────────────────────
# SQLite (default — works with zero setup)
DATABASE_URL=sqlite:///allcanlearn.db

# PostgreSQL (swap in later when you scale)
# DATABASE_URL=postgresql://user:password@localhost:5432/allcanlearn


# ── Storage Paths ────────────────────────────────────────────
# Where Piper TTS writes MP3 files
TTS_OUTPUT_DIR=tts_output

# Where old JSON episodes live (read-only, for migration only)
EPISODES_DATA_DIR=episodes_data

# Max audio files to keep on disk before cleanup (0 = unlimited)
MAX_AUDIO_FILES=500


# ── Episode Generation ───────────────────────────────────────
# Max dialogue turns per standard episode
MAX_TURNS=8

# Max turns for an "essential" (deep-dive) episode
MAX_ESSENTIAL_TURNS=16

# TTS enabled by default?
TTS_ENABLED=true


# ── Cloudflare Tunnel ────────────────────────────────────────
TUNNEL_ID=47bd781a-8d30-42c5-84f5-13e095a62572
DOMAIN=allcanlearn.uk


# ── Future: Google OAuth (not yet active) ───────────────────
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# SESSION_SECRET=a_long_random_string_here


# ── Future: Email (not yet active) ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
