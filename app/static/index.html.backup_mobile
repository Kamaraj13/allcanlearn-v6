        /* Glassmorphism Overlay */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(10, 14, 39, 0.35);
            backdrop-filter: blur(3px);
            z-index: -1;
            transition: background 0.5s;
        }
        
        body.bright-mode::before {
            background: rgba(255, 245, 200, 0.45);
        }
        
