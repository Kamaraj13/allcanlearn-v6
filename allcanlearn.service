[Unit]
Description=AllCanLearn App
After=network.target

[Service]
Type=simple
User=vikki
WorkingDirectory=/home/vikki/Desktop/roundtable/allcanlearn-v6
Environment=PATH=/home/vikki/Desktop/roundtable/allcanlearn-v6/venv/bin
ExecStart=/home/vikki/Desktop/roundtable/allcanlearn-v6/venv/bin/python3 /home/vikki/Desktop/roundtable/allcanlearn-v6/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
